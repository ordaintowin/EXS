# Database (PostgreSQL — use Neon for production)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# JWT signing secret — generate with: openssl rand -hex 32
JWT_SECRET="change_me_to_a_long_random_secret"

# Resend email API key (optional for local dev, required for production)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"

# The "From" address used when sending emails (must be a verified Resend sender)
FROM_EMAIL="noreply@yourdomain.com"

# Public app URL (no trailing slash)
NEXT_PUBLIC_APP_URL="https://yourdomain.com"

# Secret for protecting the /api/cron/* endpoints (set same value in Vercel cron config)
CRON_SECRET="change_me_to_a_random_cron_secret"

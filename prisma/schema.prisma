generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String               @id @default(uuid())
  name             String
  email            String               @unique
  phone            String
  passwordHash     String
  isAdmin          Boolean              @default(false)
  isVerified       Boolean              @default(false)
  kycVerified      Boolean              @default(false)
  referralCode     String?              @unique
  referralPoints   Int                  @default(0)
  referredBy       String?
  referrer         User?                @relation("UserReferrals", fields: [referredBy], references: [id])
  referrals        User[]               @relation("UserReferrals")
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  orders           Order[]
  kyc              KycEntry[]
  helpTickets      HelpTicket[]
  receipts         Receipt[]
  passwordResets   PasswordReset[]
  notifications    Notification[]
  orderMessages    OrderMessage[]
  referralRewards  ReferralReward[]     @relation("ReferrerRewards")
  referredRewards  ReferralReward[]     @relation("ReferredUserRewards")
  dailyQuota       UserDailyQuota?
}

model Order {
  id                  String         @id @default(uuid())
  userId              String
  user                User           @relation(fields: [userId], references: [id])
  orderType           OrderType
  serviceType         ServiceType
  service             String
  recipient           String?
  recipientName       String?
  bankName            String?
  reference           String?
  bundleLabel         String?
  amountGhs           Float
  cryptoAsset         String
  cryptoAmount        String
  cryptoRateGhs       Float
  cryptoRateUsd       Float?
  userWalletAddress   String?
  sellPayoutPhone     String?
  sellPayoutBank      String?
  // Payment method fields (for buy orders)
  paymentMethod       String?        // "bank" or "momo"
  paymentBankName     String?
  paymentBankAcct     String?
  paymentAcctName     String?
  paymentMomoProvider String?        // "MTN", "Telecel", "AirtelTigo"
  paymentMomoNumber   String?
  quotaUsed           Float?         // GHS amount counted toward daily quota
  status              OrderStatus    @default(pending)
  adminNote           String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  completedAt         DateTime?
  receipt             Receipt?
  messages            OrderMessage[]
}

enum OrderType {
  spend
  buy
  sell
}

enum ServiceType {
  bank
  momo
  airtime
  data
  buy_crypto
  sell_crypto
}

enum OrderStatus {
  waiting
  pending
  processing
  successful
  failed
  cancelled
}

model Receipt {
  id          String   @id @default(uuid())
  orderId     String   @unique
  order       Order    @relation(fields: [orderId], references: [id])
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  receiptData Json
  createdAt   DateTime @default(now())
}

model KycEntry {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  documentType    String
  documentNumber  String
  frontImage      String
  backImage       String?
  selfieImage     String
  status          KycStatus @default(pending)
  rejectionReason String?
  submittedAt     DateTime  @default(now())
  reviewedAt      DateTime?
}

enum KycStatus {
  pending
  approved
  rejected
}

model ExchangeRate {
  id         String   @id @default(uuid())
  ghsPerUsd  Float
  setByAdmin String
  note       String?
  createdAt  DateTime @default(now())
}

model WalletSettings {
  id                String   @id @default("singleton")
  USDT_TRC20        String   @default("")
  USDT_BEP20        String   @default("")
  USDT_POLYGON      String   @default("")
  USDC_BEP20        String   @default("")
  USDC_POLYGON      String   @default("")
  BTC               String   @default("")
  BNB               String   @default("")
  ETH               String   @default("")
  BINANCE_PAY       String   @default("")
  BYBIT_PAY         String   @default("")
  buyRateGhsPerUsd  Float?
  sellRateGhsPerUsd Float?
  updatedAt         DateTime @updatedAt
}

model DataBundle {
  id        String   @id @default(uuid())
  network   String
  label     String
  priceGhs  Float
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HelpTicket {
  id            String       @id @default(uuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id])
  orderId       String?
  subject       String
  message       String
  attachmentUrl String?
  status        TicketStatus @default(open)
  replies       HelpReply[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model HelpReply {
  id        String     @id @default(uuid())
  ticketId  String
  ticket    HelpTicket @relation(fields: [ticketId], references: [id])
  fromAdmin Boolean    @default(false)
  message   String
  imageUrl  String?
  createdAt DateTime   @default(now())
}

enum TicketStatus {
  open
  in_progress
  resolved
  closed
}

model PasswordReset {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}
model Notification {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  recipientType  String   @default("user")  // "user" or "admin"
  title          String
  message        String
  isRead         Boolean  @default(false)
  link           String?
  relatedOrderId String?
  createdAt      DateTime @default(now())
}

model OrderMessage {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  message   String
  fromAdmin Boolean  @default(false)
  createdAt DateTime @default(now())
}

model AdminPaymentSetting {
  id           String   @id @default(uuid())
  settingType  String   @unique // "bank_details", "mtn_details", "telecel_details", "airteltigo_details"
  bankName     String?
  bankAccount  String?
  bankAcctName String?
  momoProvider String?
  momoNumber   String?
  momoAcctName String?
  isActive     Boolean  @default(true)
  updatedAt    DateTime @updatedAt
}

model ReferralReward {
  id              String    @id @default(uuid())
  referrerId      String
  referrer        User      @relation("ReferrerRewards", fields: [referrerId], references: [id])
  referredUserId  String
  referredUser    User      @relation("ReferredUserRewards", fields: [referredUserId], references: [id])
  rewardType      String    @default("200_mb_bonus")
  rewardNetwork   String    // "mtn", "telecel", "airteltigo"
  rewardPhone     String?   // phone to send bonus to
  status          String    @default("pending")  // "pending", "approved", "sent"
  approvedBy      String?
  approvedAt      DateTime?
  sentAt          DateTime?
  createdAt       DateTime  @default(now())
}

model UserDailyQuota {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  totalSpent  Float    @default(0)
  dailyLimit  Float    @default(30000)
  date        String   // ISO date string YYYY-MM-DD
  updatedAt   DateTime @updatedAt
}
